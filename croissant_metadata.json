  "@type": "sc:Dataset",
  "name": "DOME Copilot Data Analysis",
  "description": "This dataset supports the DOME Copilot project, which evaluates the effectiveness of Large Language Models (LLMs) in automating the curation of machine learning experiment metadata from scientific publications using the DOME (Data, Optimization, Model, Evaluation) Registry schema. It contains: (1) expert human-curated DOME metadata annotations for 258 publications from the DOME Registry; (2) AI-generated (Copilot) DOME metadata for 222 benchmark and 1012 experimental cohort publications across two model versions (v0 and v2); (3) a 30-paper human-vs-AI comparative evaluation subset; (4) full-text PDFs and supplementary materials sourced from PubMed Central; and (5) publication metadata indices linking all resources by PMCID.",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "url": "https://doi.org/10.5281/zenodo.18983120",
  "version": "1.0.0",
  "datePublished": "2026-03-30",
  "dateCreated": "2025-12-04",
  "dateModified": "2026-03-30",
  "inLanguage": "en",
  "keywords": [
    "DOME Registry",
    "machine learning metadata",
    "automated curation",
    "LLM evaluation",
    "scientific publication mining",
    "NLP benchmarking",
    "BERTScore",
    "ROUGE",
    "METEOR",
    "BLEU",
    "PubMed Central",
    "reproducibility",
    "AI-assisted annotation",
    "human-AI comparison"
  ],
